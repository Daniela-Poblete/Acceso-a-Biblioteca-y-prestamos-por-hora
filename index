const DAYS=['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
const HOURS=Array.from({length:24},(_,i)=>i);
const PALETTE=['#F5A800','#2AAFE0','#3DB87A','#8B6FD4','#E07A30','#D44040','#2A8FD4','#5BB87A','#A46FD4','#E0A030','#D47040','#3AB8A0'];
let scaleMode='lineal';
let activeSedes=new Set(['Plaza Vespucio','Viña del Mar','Puerto Montt']);

const sel=document.getElementById('sede-sel');
Object.keys(HM).filter(s=>s!=='Todas las Sedes').forEach(s=>{
  const o=document.createElement('option');o.value=o.textContent=s;sel.appendChild(o);
});

function goPage(id,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  el.classList.add('active');
  if(id==='prestamos') setTimeout(()=>{drawGlobal();drawSedes();},60);
}

function setScale(m,el){
  scaleMode=m;
  document.getElementById('btn-lin').classList.toggle('active',m==='lineal');
  document.getElementById('btn-log').classList.toggle('active',m==='log');
  renderHeatmap();
}

// warm-to-dark color for light background — crema → ámbar → marrón oscuro
function cellColor(v,maxV){
  if(v<=0) return 'rgba(0,0,0,0.04)';
  const S=[[0,[245,240,230]],[0.12,[240,210,140]],[0.3,[220,170,40]],[0.55,[180,120,0]],[0.78,[120,70,0]],[1,[50,25,0]]];
  let t=scaleMode==='log'?Math.log1p(v)/Math.log1p(maxV):v/maxV;
  t=Math.min(t,1);
  let c0,c1,f;
  for(let i=0;i<S.length-1;i++){if(t<=S[i+1][0]){f=(t-S[i][0])/(S[i+1][0]-S[i][0]);c0=S[i][1];c1=S[i+1][1];break;}}
  if(!c0){c0=S[S.length-2][1];c1=S[S.length-1][1];f=1;}
  return `rgb(${~~(c0[0]+(c1[0]-c0[0])*f)},${~~(c0[1]+(c1[1]-c0[1])*f)},${~~(c0[2]+(c1[2]-c0[2])*f)})`;
}

function renderHeatmap(){
  const sede=document.getElementById('sede-sel').value;
  const data=HM[sede]||{};
  const vals=Object.values(data).filter(v=>v>0);
  const maxV=vals.length?Math.max(...vals):1;
  document.getElementById('hm-hrs').innerHTML=HOURS.map(h=>`<div class="hm-hl">${h}</div>`).join('');
  document.getElementById('hm-maxlbl').textContent=maxV.toFixed(0);
  const grid=document.getElementById('hm-grid');
  grid.innerHTML='';
  const hT=Array(24).fill(0),dT=Array(7).fill(0);
  DAYS.forEach((day,d)=>{
    const row=document.createElement('div');row.className='hm-row';
    const lbl=document.createElement('div');lbl.className='hm-dl';lbl.textContent=day;
    const cells=document.createElement('div');cells.className='hm-cells';
    HOURS.forEach(h=>{
      const v=data[`${d}-${h}`]||0;
      hT[h]+=v;dT[d]+=v;
      const c=document.createElement('div');c.className='hm-cell';
      c.style.background=cellColor(v,maxV);
      c.addEventListener('mousemove',e=>{
        const tt=document.getElementById('tt');
        document.getElementById('tt-v').textContent=v.toFixed(1);
        document.getElementById('tt-l').textContent=`${day} · ${h}:00 h`;
        tt.classList.add('show');
        tt.style.left=(e.clientX+14)+'px';tt.style.top=(e.clientY-58)+'px';
      });
      c.addEventListener('mouseleave',()=>document.getElementById('tt').classList.remove('show'));
      cells.appendChild(c);
    });
    row.appendChild(lbl);row.appendChild(cells);grid.appendChild(row);
  });
  const ph=hT.indexOf(Math.max(...hT));
  const pd=dT.indexOf(Math.max(...dT));
  const act=HOURS.filter(h=>hT[h]>maxV*0.3*7);
  document.getElementById('sm-hora').textContent=ph+':00';
  document.getElementById('sm-dia').textContent=DAYS[pd];
  document.getElementById('sm-max').textContent=maxV.toFixed(0);
  document.getElementById('sm-rango').textContent=act.length?`${Math.min(...act)}–${Math.max(...act)} h`:'–';
  document.getElementById('g1').textContent=vals.reduce((a,b)=>a+b,0).toLocaleString('es-CL');
}

function initLoans(){
  const sorted=Object.entries(LOANS).sort((a,b)=>b[1].total-a[1].total);
  const maxT=sorted[0][1].total;
  document.getElementById('bar-chart').innerHTML=sorted.map(([name,s],i)=>{
    const pct=(s.total/maxT*100).toFixed(1);
    const op=0.2+(1-i/sorted.length)*0.8;
    return `<div class="br-row">
      <div class="br-name" title="${name}">${name}</div>
      <div class="br-track">
        <div class="br-fill" style="width:${pct}%;background:rgba(245,168,0,${op.toFixed(2)})">
          <span>${s.total.toLocaleString('es-CL')}</span>
        </div>
      </div>
    </div>`;
  }).join('');

  const pc=document.getElementById('sede-pills');
  Object.keys(LOANS).forEach((sede,i)=>{
    const col=PALETTE[i%PALETTE.length];
    const pill=document.createElement('div');
    pill.className='pill'+(activeSedes.has(sede)?' on':'');
    if(activeSedes.has(sede)){pill.style.background=col;pill.style.color='#fff';pill.style.borderColor='transparent';}
    pill.setAttribute('data-col',col);
    pill.textContent=LOANS[sede].code+' '+sede;
    pill.onclick=()=>{
      if(activeSedes.has(sede)){activeSedes.delete(sede);pill.classList.remove('on');pill.style.background='';pill.style.color='';pill.style.borderColor='';}
      else{activeSedes.add(sede);pill.classList.add('on');pill.style.background=col;pill.style.color='#fff';pill.style.borderColor='transparent';}
      drawSedes();
    };
    pc.appendChild(pill);
  });
}

function drawGlobal(){
  const gh={};
  Object.values(LOANS).forEach(s=>Object.entries(s.hours).forEach(([h,v])=>{gh[+h]=(gh[+h]||0)+v;}));
  const labels=Array.from({length:17},(_,i)=>i+6);
  const vals=labels.map(h=>gh[h]||0);
  const cv=document.getElementById('cv-global');
  const dpr=window.devicePixelRatio||1;
  cv.width=(cv.parentElement.clientWidth||460)*dpr;
  cv.height=300*dpr;cv.style.height='300px';
  const ctx=cv.getContext('2d');
  const W=cv.width,H=cv.height,p={t:12,r:10,b:32,l:52};
  const cW=W-p.l-p.r,cH=H-p.t-p.b,maxV=Math.max(...vals);
  ctx.clearRect(0,0,W,H);
  const xS=cW/(labels.length-1);
  ctx.font=`${8*dpr}px Inter, sans-serif`;

  [0,.25,.5,.75,1].forEach(t=>{
    const y=p.t+cH-t*cH;
    ctx.beginPath();ctx.moveTo(p.l,y);ctx.lineTo(W-p.r,y);
    ctx.strokeStyle='rgba(0,0,0,0.07)';ctx.lineWidth=dpr;ctx.stroke();
    ctx.fillStyle='rgba(0,0,0,0.35)';ctx.textAlign='right';
    ctx.fillText((~~(t*maxV)).toLocaleString('es-CL'),p.l-4*dpr,y+3*dpr);
  });

  const g=ctx.createLinearGradient(0,p.t,0,H-p.b);
  g.addColorStop(0,'rgba(245,168,0,0.3)');
  g.addColorStop(1,'rgba(245,168,0,0.0)');
  ctx.beginPath();ctx.moveTo(p.l,H-p.b);
  labels.forEach((_,i)=>ctx.lineTo(p.l+i*xS,p.t+cH-(vals[i]/maxV)*cH));
  ctx.lineTo(p.l+(labels.length-1)*xS,H-p.b);
  ctx.closePath();ctx.fillStyle=g;ctx.fill();

  ctx.beginPath();
  labels.forEach((_,i)=>{const x=p.l+i*xS,y=p.t+cH-(vals[i]/maxV)*cH;if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);});
  ctx.strokeStyle='#F5A800';ctx.lineWidth=2*dpr;ctx.stroke();

  labels.forEach((_,i)=>{
    const x=p.l+i*xS,y=p.t+cH-(vals[i]/maxV)*cH;
    ctx.beginPath();ctx.arc(x,y,2.5*dpr,0,Math.PI*2);ctx.fillStyle='#F5A800';ctx.fill();
    ctx.fillStyle='rgba(0,0,0,0.3)';ctx.textAlign='center';
    ctx.fillText(labels[i]+'h',x,H-p.b+12*dpr);
  });
}

function drawSedes(){
  const cv=document.getElementById('cv-sedes');
  const dpr=window.devicePixelRatio||1;
  cv.width=(cv.parentElement.clientWidth||700)*dpr;
  cv.height=240*dpr;cv.style.height='240px';
  const ctx=cv.getContext('2d');
  const W=cv.width,H=cv.height,p={t:12,r:110,b:32,l:52};
  const cW=W-p.l-p.r,cH=H-p.t-p.b;
  const hR=Array.from({length:17},(_,i)=>i+6);
  const sArr=[...activeSedes];
  ctx.clearRect(0,0,W,H);
  if(!sArr.length)return;
  ctx.font=`${8*dpr}px Inter, sans-serif`;

  const allV=sArr.flatMap(s=>hR.map(h=>LOANS[s]?.hours[h]||0));
  const maxV=Math.max(...allV,1);
  const xS=cW/(hR.length-1);

  [0,.25,.5,.75,1].forEach(t=>{
    const y=p.t+cH-t*cH;
    ctx.beginPath();ctx.moveTo(p.l,y);ctx.lineTo(W-p.r,y);
    ctx.strokeStyle='rgba(0,0,0,0.07)';ctx.lineWidth=dpr;ctx.stroke();
    ctx.fillStyle='rgba(0,0,0,0.35)';ctx.textAlign='right';
    ctx.fillText((~~(t*maxV)).toLocaleString('es-CL'),p.l-4*dpr,y+3*dpr);
  });
  ctx.fillStyle='rgba(0,0,0,0.3)';ctx.textAlign='center';
  hR.forEach((_,i)=>ctx.fillText(hR[i]+'h',p.l+i*xS,H-p.b+12*dpr));

  const allKeys=Object.keys(LOANS);
  sArr.forEach((sede,si)=>{
    const col=PALETTE[allKeys.indexOf(sede)%PALETTE.length];
    const vals=hR.map(h=>LOANS[sede]?.hours[h]||0);
    ctx.beginPath();
    vals.forEach((v,i)=>{const x=p.l+i*xS,y=p.t+cH-(v/maxV)*cH;if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);});
    ctx.strokeStyle=col;ctx.lineWidth=2*dpr;ctx.stroke();
    vals.forEach((v,i)=>{
      const x=p.l+i*xS,y=p.t+cH-(v/maxV)*cH;
      ctx.beginPath();ctx.arc(x,y,2.5*dpr,0,Math.PI*2);ctx.fillStyle=col;ctx.fill();
    });
    const ly=p.t+si*16*dpr;
    ctx.fillStyle=col;ctx.fillRect(W-p.r+8*dpr,ly,10*dpr,2.5*dpr);
    ctx.fillStyle='rgba(0,0,0,0.5)';ctx.textAlign='left';
    ctx.fillText(LOANS[sede]?.code||'',W-p.r+22*dpr,ly+5*dpr);
  });
}

document.addEventListener('DOMContentLoaded',()=>{
  renderHeatmap();
  initLoans();
  window.addEventListener('resize',()=>{
    renderHeatmap();
    if(document.getElementById('page-prestamos').classList.contains('active')){drawGlobal();drawSedes();}
  });
});
